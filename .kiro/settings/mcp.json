{
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": {},
      "disabled": false,
      "autoApprove": []
    },
    "hexdocs-mcp": {
      "command": "npx",
      "args": ["-y", "hexdocs-mcp@0.5.0"],
      "env": {
        "HEXDOCS_MCP_DEFAULT_EMBEDDING_MODEL": "nomic-embed-text"
      },
      "disabled": false,
      "autoApprove": []
    },
    "aws-docs": {
      "command": "uvx",
      "args": ["awslabs.aws-documentation-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": true,
      "autoApprove": []
    },
    "postgres-mcp": {
      "command": "uvx",
      "args": [
        "postgres-mcp",
        "--access-mode=unrestricted"
      ],
      "env": {
        "DATABASE_URI": "postgresql://postgres:postgres@localhost:5432/vigil_dev"
      },
      "disabled": true,
      "autoApprove": []
    },
    "tidewave": {
      "type": "http",
      "url": "http://localhost:4000/tidewave/mcp",
      "disabled": true
    }
  }
}
